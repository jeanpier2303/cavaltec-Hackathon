APP_NAME="Privacy Compliance API"
APP_ENV=development
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
TOKEN_TYPE=bearer

MYSQL_DATABASE=privacy_compliance
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

DATABASE_URL=mysql+pymysql://app_user:app_password@mysql:3306/privacy_compliance

OPENROUTER_API_KEY=your-openrouter-api-key
